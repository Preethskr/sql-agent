# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to: anthropic | groq | gemini
LLM_PROVIDER=anthropic

# Anthropic (production)
ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (free tier — https://console.groq.com)
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier — https://aistudio.google.com)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash

# ── Database ──────────────────────────────────────────────────────────────────
# Set DB_TYPE to: postgres | oracle | tibero | sqlserver
DB_TYPE=postgres

# Common
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# PostgreSQL / SQL Server
DB_PORT=5432
DB_NAME=your_database_name

# Oracle  (DB_PORT default 1521)
# DB_PORT=1521
# DB_SERVICE_NAME=orcl

# Tibero  (uses ODBC — configure DSN in ODBC Data Source Administrator first)
# DB_DSN=your_tibero_dsn_name

# SQL Server  (adjust ODBC driver version if needed)
# DB_PORT=1433
# DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# ── Agent Settings (optional) ─────────────────────────────────────────────────
ROW_LIMIT=1000
MAX_RETRIES=3
MAX_ITERATIONS=10
QUERY_TIMEOUT=10
CARDINALITY_LIMIT=50

# ── Conversation Memory ────────────────────────────────────────────────────────
# STORE_TYPE=json           # development  — saves to sessions/ folder
# STORE_TYPE=postgres       # production   — saves to PostgreSQL
STORE_TYPE=json
SESSIONS_DIR=sessions
SESSIONS_WINDOW_SIZE=10         # messages kept in full per turn
SESSIONS_SUMMARY_THRESHOLD=20   # trigger summarization above this

# PostgreSQL sessions store (only needed when STORE_TYPE=postgres)
# SESSIONS_DB_HOST=localhost
# SESSIONS_DB_PORT=5432
# SESSIONS_DB_NAME=agent_sessions
# SESSIONS_DB_USER=
# SESSIONS_DB_PASSWORD=
